{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "rootDir": "..",
    "baseUrl": ".",
    "paths": {
      "@/types/*": ["../src/types/*"]
    }
  },
  "include": ["**/*.ts", "../src/types/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
